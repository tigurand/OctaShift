<Window x:Class="OctaShift.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OctaShift"
        Icon="OctaShift.ico"
        Height="720"
        Width="760"
        MinHeight="520"
        MinWidth="620"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="MIDI Files">
            <ListBox x:Name="FileListBox"
                Margin="0,5"
                SelectionMode="Extended"/>
        </GroupBox>

        <StackPanel Grid.Row="1" Margin="0,15,0,0">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Add Files" Width="110" Margin="5" Click="AddFiles_Click"/>
                <Button Content="Add Folder" Width="110" Margin="5" Click="AddFolder_Click"/>
                <Button Content="Remove Selected" Width="130" Margin="5" Click="RemoveSelected_Click"/>
            </StackPanel>

            <GroupBox Header="Processing Mode" Margin="0,15,0,0">
                <StackPanel Margin="5">

                    <RadioButton x:Name="ClosestModeRadio"
                     Content="Option A - Closest Octave Mapping"
                     IsChecked="True"
                     Margin="0,3"
                     Checked="SettingsChanged"
                     Unchecked="SettingsChanged">
                        <RadioButton.ToolTip>
                            Fix each note individually by moving it to the closest playable octave.
                            Best for simple melodies or small fixes.
                        </RadioButton.ToolTip>
                    </RadioButton>

                    <RadioButton x:Name="GlobalShiftRadio"
                     Content="Option B - Global Track Shift First"
                     Margin="0,3"
                     Checked="SettingsChanged"
                     Unchecked="SettingsChanged">
                        <RadioButton.ToolTip>
                            Shifts the entire song up or down first, then fixes remaining notes.
                            Best for full piano songs or bass-heavy music.
                        </RadioButton.ToolTip>
                    </RadioButton>

                </StackPanel>
            </GroupBox>

            <GroupBox Header="Key Mode" Margin="0,10,0,0">
                <StackPanel Margin="5">

                    <RadioButton x:Name="Mode37Radio"
                     Content="37 Keys (Final Fantasy XIV, etc)"
                     IsChecked="True"
                     Margin="0,3"
                     Checked="SettingsChanged"
                     Unchecked="SettingsChanged"/>

                    <RadioButton x:Name="Mode36Radio"
                     Content="36 Keys (Where Winds Meet)"
                     Margin="0,3"
                     Checked="SettingsChanged"
                     Unchecked="SettingsChanged"/>

                    <RadioButton x:Name="Mode15Radio"
                     Content="15 Keys (Heartopia)"
                     Margin="0,3"
                     Checked="SettingsChanged"
                     Unchecked="SettingsChanged"/>

                </StackPanel>
            </GroupBox>

            <CheckBox x:Name="RemovePercussionCheck"
                  Content="Remove Percussion Tracks"
                  Margin="0,15,0,5"
                  Checked="SettingsChanged"
                  Unchecked="SettingsChanged"/>

            <CheckBox x:Name="MergeTracksCheck"
                  Content="Merge all tracks into single track"
                  Margin="0,5"
                  Checked="SettingsChanged"
                  Unchecked="SettingsChanged">
                        <CheckBox.ToolTip>
                            Combine all tracks into one track.
                        </CheckBox.ToolTip>
                    </CheckBox>

            <CheckBox x:Name="MergeChannelsCheck"
                  Content="Merge all channels into single channel"
                  Margin="0,5"
                  Checked="SettingsChanged"
                  Unchecked="SettingsChanged">
                        <CheckBox.ToolTip>
                            Force all notes and channel events into single channel while keeping tracks.
                        </CheckBox.ToolTip>
                    </CheckBox>

            <CheckBox x:Name="TrimSilenceCheck"
                  Content="Trim leading silence (start immediately)"
                  Margin="0,5"
                  Checked="SettingsChanged"
                  Unchecked="SettingsChanged">
                        <CheckBox.ToolTip>
                            If the song starts late, move all events so first note starts at time 0.
                        </CheckBox.ToolTip>
                    </CheckBox>

            <StackPanel Orientation="Horizontal" Margin="0,10">
                <TextBox x:Name="OutputFolderTextBox"
             Width="500"
             IsReadOnly="True"
             Margin="0,0,5,0"/>

                <Button Content="Select Output Folder"
            Click="SelectOutputFolder_Click"/>
            </StackPanel>

            <Button Content="Process"
                    Height="45"
                    FontSize="14"
                    Margin="0,10"
                    Click="ProcessFiles_Click"/>

            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       FontWeight="SemiBold"
                       Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>
