<Window x:Class="OctaShift.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OctaShift"
        Icon="OctaShift.ico"
        Height="640"
        Width="1100"
        MinHeight="520"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TabControl>
            <TabItem Header="Conversion">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <GroupBox Header="MIDI Files" Grid.Row="0">
                                <ListBox x:Name="FileListBox"
                                         Margin="5"
                                         SelectionMode="Extended"/>
                            </GroupBox>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                <Button Content="Add Files" Width="120" Margin="5" Click="AddFiles_Click"/>
                                <Button Content="Add Folder" Width="120" Margin="5" Click="AddFolder_Click"/>
                                <Button Content="Remove Selected" Width="150" Margin="5" Click="RemoveSelected_Click"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="1" Margin="15,0,0,5" VerticalAlignment="Stretch">
                            <GroupBox Header="Processing Mode">
                                <StackPanel Margin="5">
                                    <RadioButton x:Name="ClosestModeRadio"
                                                 Content="Closest Octave Mapping"
                                                 IsChecked="True"
                                                 Margin="0,3"
                                                 Checked="SettingsChanged"
                                                 Unchecked="SettingsChanged">
                                        <RadioButton.ToolTip>
                                            Fix each note individually by moving it to the closest playable octave.
                                            Best for simple melodies or small fixes.
                                        </RadioButton.ToolTip>
                                    </RadioButton>

                                    <RadioButton x:Name="GlobalShiftRadio"
                                                 Content="Global Track Shift First"
                                                 Margin="0,3"
                                                 Checked="SettingsChanged"
                                                 Unchecked="SettingsChanged">
                                        <RadioButton.ToolTip>
                                            Shifts the entire song up or down first, then fixes remaining notes.
                                            Best for full piano songs or bass-heavy music.
                                        </RadioButton.ToolTip>
                                    </RadioButton>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Key Mode">
                                <StackPanel Margin="5">
                                    <RadioButton x:Name="Mode37Radio"
                                                 Content="37 Keys (Final Fantasy XIV, etc)"
                                                 IsChecked="True"
                                                 Margin="0,3"
                                                 Checked="SettingsChanged"
                                                 Unchecked="SettingsChanged"/>

                                    <RadioButton x:Name="Mode36Radio"
                                                 Content="36 Keys (Where Winds Meet)"
                                                 Margin="0,3"
                                                 Checked="SettingsChanged"
                                                 Unchecked="SettingsChanged"/>

                                    <RadioButton x:Name="Mode15Radio"
                                                 Content="15 Keys (Heartopia)"
                                                 Margin="0,3"
                                                 Checked="SettingsChanged"
                                                 Unchecked="SettingsChanged"/>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Options">
                                <StackPanel Margin="5">
                                    <CheckBox x:Name="RemovePercussionCheck"
                                              Content="Remove Percussion Tracks"
                                              Margin="0,0,0,5"
                                              Checked="SettingsChanged"
                                              Unchecked="SettingsChanged"/>

                                    <CheckBox x:Name="MergeTracksCheck"
                                              Content="Merge all tracks into single track"
                                              Margin="0,0,0,5"
                                              Checked="SettingsChanged"
                                              Unchecked="SettingsChanged">
                                        <CheckBox.ToolTip>
                                            Combine all tracks into one track.
                                        </CheckBox.ToolTip>
                                    </CheckBox>

                                    <CheckBox x:Name="MergeChannelsCheck"
                                              Content="Merge all channels into single channel"
                                              Margin="0,0,0,5"
                                              Checked="SettingsChanged"
                                              Unchecked="SettingsChanged">
                                        <CheckBox.ToolTip>
                                            Force all notes and channel events into single channel while keeping tracks.
                                        </CheckBox.ToolTip>
                                    </CheckBox>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                                        <CheckBox x:Name="SimplifyNotesCheck"
                                                  Content="Limit simultaneous notes"
                                                  Checked="SettingsChanged"
                                                  Unchecked="SettingsChanged"
                                                  VerticalAlignment="Center"/>

                                        <TextBox x:Name="SimplifyNotesCountTextBox"
                                                 Width="60"
                                                 Margin="10,0,5,0"
                                                 TextChanged="NumericSettingTextChanged"
                                                 IsEnabled="{Binding IsChecked, ElementName=SimplifyNotesCheck}"
                                                 VerticalContentAlignment="Center"/>

                                        <TextBlock Text="notes max per moment"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel.ToolTip>
                                            Limit how many notes can start at exactly the same time (percussion ignored). Extra notes are dropped by picking spread pitches like lowest/middle/highest.
                                        </StackPanel.ToolTip>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                                        <CheckBox x:Name="TransposeNotesCheck"
                                                  Content="Transpose notes by"
                                                  Checked="SettingsChanged"
                                                  Unchecked="SettingsChanged"
                                                  VerticalAlignment="Center"/>

                                        <TextBox x:Name="TransposeNotesCountTextBox"
                                                 Width="60"
                                                 Margin="10,0,5,0"
                                                 TextChanged="NumericSettingTextChanged"
                                                 IsEnabled="{Binding IsChecked, ElementName=TransposeNotesCheck}"
                                                 VerticalContentAlignment="Center"/>

                                        <TextBlock Text="semitones"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel.ToolTip>
                                            Transposes all non-percussion notes by the specified number of semitones. Only for 37/36 keys.
                                        </StackPanel.ToolTip>
                                    </StackPanel>

                                    <CheckBox x:Name="TrimSilenceCheck"
                                              Content="Trim leading silence (start immediately)"
                                              Checked="SettingsChanged"
                                              Unchecked="SettingsChanged">
                                        <CheckBox.ToolTip>
                                            If the song starts late, move all events so first note starts at time 0.
                                        </CheckBox.ToolTip>
                                    </CheckBox>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5,10,0,5" VerticalAlignment="Center">
                        <TextBox x:Name="OutputFolderTextBox"
                                 MinWidth="520"
                                 IsReadOnly="True"
                                 Margin="5,0,8,0"/>

                        <Button Content="Select Output Folder"
                                Width="170"
                                Click="SelectOutputFolder_Click"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button Content="Process"
                                Grid.Row="0"
                                Height="45"
                                FontSize="14"
                                Margin="5,0,5,8"
                                HorizontalAlignment="Stretch"
                                Click="ProcessFiles_Click"/>

                        <TextBlock x:Name="StatusText"
                                   Grid.Row="1"
                                   Text="Ready"
                                   FontWeight="SemiBold"
                                   Margin="5,0,0,0"
                                   HorizontalAlignment="Left"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="App Settings">
                <StackPanel Margin="5">
                    <GroupBox Header="Updates">
                        <StackPanel Margin="5">
                            <CheckBox x:Name="AutoUpdateCheck"
                                      Content="Enable auto-update (GitHub releases)"
                                      Margin="0,3"
                                      Checked="SettingsChanged"
                                      Unchecked="SettingsChanged"/>

                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <Button Content="Check for Updates"
                                        Width="150"
                                        Click="CheckUpdates_Click"/>
                                <TextBlock x:Name="UpdateStatusText"
                                           Text="Not checked"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
